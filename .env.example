# =============================================================================
# stern-open-ingest — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in only the keys for the features you plan
# to use. Every section is independently optional; missing keys disable just
# the features that depend on them.
#
#   cp .env.example .env
#   set -a; source .env; set +a
# =============================================================================

# ----- OCR backend: DotsOCR on a CUDA GPU (dots-ocr) ------------------------
# No API keys. Needs a CUDA-equipped host. Model weights are pulled from
# Hugging Face Hub on first cold-start.
#
# Memory ceiling for the DotsOCR GPU container. Default 32 GB.
OCR_GPU_MEMORY_IN_GB=32
# Memory ceiling for the Ovis2.5 figure-OCR GPU container. Default 24 GB.
OVIS_MEMORY_IN_GB=24


# ----- LLM / VLM enrichment --------------------------------------------------
# Used for table/figure summarization, page classification, table merging, and
# other VLM enrichment. Each provider key is independently optional.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Gemini is used as an LLM/VLM provider (e.g. table merging), not as an OCR
# backend.
GEMINI_API_KEY=
# Only needed if you select a Qwen-backed OCR/enrichment path.
QWEN_API_KEY=

